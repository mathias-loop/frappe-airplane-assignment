 "client_script": "frappe.web_form.after_load = () => {\n    // 1. Get the Flight from the URL\n    const urlParams = new URLSearchParams(window.location.search);\n    const flight = urlParams.get('flight');\n\n    if (flight) {\n        // 2. Set the Price (The missing piece!)\n        frappe.web_form.set_value('flight_price', 1500);\n        \n        // 3. Make them Read Only\n        frappe.web_form.set_df_property('flight', 'read_only', 1);\n        frappe.web_form.set_df_property('flight_price', 'read_only', 1);\n    }\n}",
